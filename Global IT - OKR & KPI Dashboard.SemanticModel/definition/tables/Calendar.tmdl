	partition Calendar = calculated
		mode: import
		source = ```
				
				-- Buscamos el rango dinámico basado en tu tabla de hechos de OKRs
				VAR MinDate = MIN('results'[Date]) 
				VAR MaxDate = MAX('results'[Date])
				
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( MinDate, MaxDate ),
				    "Year", YEAR ( [Date] ),
				    "Month No", MONTH ( [Date] ),
				    "Month Name", FORMAT ( [Date], "MMMM", "en-US" ), -- Forzado en-US por estándar global
				    "Month-Year", FORMAT ( [Date], "MMM-yy", "en-US" ), 
				    "Month-Year Sort", FORMAT ( [Date], "YYYYMM" ),
				    
				    -- Lógica Fiscal Accenture (Septiembre - Agosto)
				    "Fiscal Year", "FY" & RIGHT(FORMAT(IF(MONTH([Date]) >= 9, YEAR([Date]) + 1, YEAR([Date])), "0000"), 2),
				    "Fiscal Quarter", "FQ" & SWITCH( TRUE(),
				        MONTH([Date]) IN {9, 10, 11}, "1",
				        MONTH([Date]) IN {12, 1, 2}, "2",
				        MONTH([Date]) IN {3, 4, 5}, "3",
				        "4"
				    ),
				    "Fiscal Month No", MOD( MONTH([Date]) - 9 + 12, 12 ) + 1
				)
				```

	annotation PBI_Id = c766ec81d52c4230afe9552fc684a64c

