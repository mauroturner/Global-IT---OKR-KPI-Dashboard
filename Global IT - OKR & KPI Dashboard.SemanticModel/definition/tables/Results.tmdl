				let
				    Origen = Excel.Workbook(File.Contents("C:\Users\mauro\Desktop\Accenture\Dashboard okrs\Datasets\okrs.xlsx"), null, true),
				    Results_Sheet = Origen{[Item="Results",Kind="Sheet"]}[Data],
